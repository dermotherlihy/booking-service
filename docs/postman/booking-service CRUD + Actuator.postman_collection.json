{
  "info": {
    "name": "booking-service CRUD + Actuator + Metrics",
    "_postman_id": "e8a88e38-3d54-4ec8-8f90-f9ebf3892ac0",
    "description": "CRUD for /v1/bookings, actuator health/info, and metrics endpoints including http.server.requests and bookings.created.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Actuator",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/info",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "info"
              ]
            }
          }
        },
        {
          "name": "Metrics Index",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "metrics"
              ]
            }
          }
        },
        {
          "name": "HTTP Requests (count + latency)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/metrics/http.server.requests",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "metrics",
                "http.server.requests"
              ]
            }
          }
        },
        {
          "name": "HTTP Requests - Server Errors (5xx)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/metrics/http.server.requests?tag=outcome:SERVER_ERROR",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "metrics",
                "http.server.requests"
              ],
              "query": [
                {
                  "key": "tag",
                  "value": "outcome:SERVER_ERROR"
                }
              ]
            }
          }
        },
        {
          "name": "HTTP Requests - Client Errors (4xx)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/metrics/http.server.requests?tag=outcome:CLIENT_ERROR",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "metrics",
                "http.server.requests"
              ],
              "query": [
                {
                  "key": "tag",
                  "value": "outcome:CLIENT_ERROR"
                }
              ]
            }
          }
        },
        {
          "name": "Business Metric - bookings.created",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/metrics/bookings.created",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "metrics",
                "bookings.created"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "List Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings"
              ]
            }
          }
        },
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('bookingId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"classId\": \"{{classId}}\",\n  \"startsAt\": \"{{startsAtCreate}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings"
              ]
            }
          }
        },
        {
          "name": "Get Booking by Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/bookings/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings",
                "{{bookingId}}"
              ]
            }
          }
        },
        {
          "name": "Update Booking by Id",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"classId\": \"{{classIdUpdated}}\",\n  \"startsAt\": \"{{startsAtUpdate}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/bookings/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings",
                "{{bookingId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Booking by Id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/bookings/{{bookingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "bookings",
                "{{bookingId}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "user-1"
    },
    {
      "key": "classId",
      "value": "class-1"
    },
    {
      "key": "classIdUpdated",
      "value": "class-2"
    },
    {
      "key": "startsAtCreate",
      "value": "2026-03-24T10:15:30Z"
    },
    {
      "key": "startsAtUpdate",
      "value": "2026-03-25T10:15:30Z"
    },
    {
      "key": "bookingId",
      "value": ""
    }
  ]
